# Primary price feed (Chaos Edge)
CHAOS_EDGE_BASE_URL=https://api.edge-inference.chaoslabs.xyz
CHAOS_EDGE_API_KEY=
CHAOS_EDGE_FEED_SOL_USD=
CHAOS_EDGE_FEED_ETH_USD=
CHAOS_EDGE_FEED_BTC_USD=

# Solana RPC (wallet sync + Jupiter)
NEXT_PUBLIC_SOLANA_RPC_URL=

# Redis (required for durable push subscriptions/state across serverless instances)
REDIS_URL=

# Web push (required for push notifications)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com
CRON_SECRET=

# Jupiter Plugin local development toggle
NEXT_PUBLIC_IS_PLUGIN_DEV=true
